# OpenAI (필수 — YouTube/Instagram 레시피 추출)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Firebase Admin (서버 전용 — JSON 파일을 repo에 두지 않음) ──
#
# 1) 다운로드한 서비스 계정 JSON 경로로 환경 변수 값 생성:
#    node scripts/print-firebase-env.mjs ~/Downloads/your-project-firebase-adminsdk-xxxxx.json
#
# 2) 아래 둘 중 하나만 .env 에 넣으세요 (동시에 넣어도 BASE64 우선):
#
# 방법 A — JSON 한 줄
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
#
# 방법 B — Base64 (Vercel 등록 권장)
# FIREBASE_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# 무료 AI 분석 횟수 (로그인 계정, Firestore freeAnalysisRemaining 초기값)
FREE_ANALYSIS_LIMIT=5

# AI 일일 사용 제한 (게스트/비로그인, 서버 파일 저장)
AI_DAILY_LIMIT=5
AI_USAGE_TIMEZONE=Asia/Seoul

# Vercel: Dashboard → Project → Settings → Environment Variables
# OPENAI_API_KEY, FIREBASE_SERVICE_ACCOUNT_BASE64 등록 후 Redeploy

# 서버 포트 (로컬 serve.sh 전용)
PORT=8765
